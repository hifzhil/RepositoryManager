<Window x:Class="RepositoryManager.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RepositoryManager.GUI.ViewModels"
        xmlns:conv="clr-namespace:RepositoryManager.GUI.Converters"
        mc:Ignorable="d"
        Title="Repository Manager"
        Width="1200" Height="780"
        MinWidth="860" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter">

    <Window.Resources>
        <conv:NullToVisibilityConverter         x:Key="NullToVis"/>
        <conv:NullToVisibilityInverseConverter  x:Key="NullToVisInv"/>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolConverter              x:Key="InvBool"/>
        <conv:StringContainsConverter           x:Key="StrContains"/>
        <conv:IntZeroToVisibilityConverter      x:Key="IntZeroToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- =========================================================
             ROW 0 — TOP TOOLBAR
             ========================================================= -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: brand + actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Repository Manager" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,24,0"/>

                    <Button Content="&#xE898;  Upload"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding UploadCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Upload JSON or XML file (or drag and drop)"/>

                    <Button Content="&#xE72C;  Refresh"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Reload all repository items"/>

                    <Button Content="&#xE74D;  Delete"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding DeleteCommand}"
                            Margin="0,0,8,0"
                            ToolTip="Delete selected item"/>

                    <Button Content="&#xE78C;  Export"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ExportCommand}"
                            ToolTip="Save selected item to disk"/>
                </StackPanel>

                <!-- Right: busy indicator + theme toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Busy spinner -->
                    <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="8" CenterY="8"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>

                    <!-- Theme toggle -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ToggleButton IsChecked="{Binding IsDarkTheme}" Width="44" Height="22"
                                      VerticalAlignment="Center" Cursor="Hand"
                                      ToolTip="Toggle dark/light theme">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Track" CornerRadius="11" Width="44" Height="22"
                                            Background="{StaticResource BgTertiary}"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1">
                                        <Ellipse x:Name="Thumb" Width="16" Height="16"
                                                 Fill="{StaticResource TextMuted}"
                                                 HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Thumb" Property="Fill"       Value="White"/>
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="Thumb" Property="Margin"     Value="0,0,2,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <TextBlock Text="&#xE793;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =========================================================
             ROW 1 — MAIN CONTENT (LEFT PANEL + RIGHT PANEL)
             ========================================================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Grid Grid.Column="0" Background="{StaticResource BgSecondary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- search box -->
                    <RowDefinition Height="Auto"/>
                    <!-- stats -->
                    <RowDefinition Height="*"/>
                    <!-- list -->
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border Grid.Row="0" Padding="12,10" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource SearchBoxStyle}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE721;  Search items..." FontFamily="Segoe MDL2 Assets,Segoe UI"
                                   Foreground="{StaticResource TextMuted}" FontSize="12"
                                   IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Visibility>
                                <Binding Path="SearchText" Converter="{StaticResource NullToVisInv}"/>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Stats row -->
                <Border Grid.Row="1" Padding="10,8" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                        Background="{StaticResource BgTertiary}">
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource StatCardStyle}" Padding="10,6" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalItems}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Total" FontSize="10" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Padding="10,6" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="{Binding JsonCount}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource Warning}" HorizontalAlignment="Center"/>
                                <TextBlock Text="JSON" FontSize="10" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCardStyle}" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="{Binding XmlCount}" FontSize="18" FontWeight="Bold"
                                           Foreground="#3B82F6" HorizontalAlignment="Center"/>
                                <TextBlock Text="XML" FontSize="10" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Item list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem}"
                         Style="{StaticResource RepoListStyle}"
                         ItemContainerStyle="{StaticResource RepoListItemStyle}"
                         Padding="8,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding UploadedAtFormatted}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Type badge -->
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding TypeBadgeColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="10" FontWeight="Bold"
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <Border Grid.Row="2" Visibility="{Binding FilteredItems.Count, Converter={StaticResource IntZeroToVis}}"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                   Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No items found" FontSize="13" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Upload a JSON or XML file" FontSize="11" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Separator}" Cursor="SizeWE"/>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="2" Background="{StaticResource BgPrimary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header -->
                    <RowDefinition Height="*"/>
                    <!-- preview -->
                </Grid.RowDefinitions>

                <!-- Detail header (shown when something is selected) -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgSecondary}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,0,1"
                        Padding="16,10"
                        Visibility="{Binding SelectedItem, Converter={StaticResource NullToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedItem.Name}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding SelectedItem.TypeBadgeColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding SelectedItem.TypeLabel}" FontSize="10"
                                               FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="{Binding SelectedItem.UploadedAtFormatted}" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="&#xE78C;  Export" Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding ExportCommand}" Margin="0,0,8,0"/>
                            <Button Content="&#xE74D;  Delete" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding DeleteCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Preview area -->
                <Grid Grid.Row="1">
                    <!-- Content preview when item is selected -->
                    <TextBox Style="{StaticResource PreviewTextStyle}"
                             Text="{Binding SelectedItem.Content, Mode=OneWay}"
                             Visibility="{Binding SelectedItem, Converter={StaticResource NullToVis}}"/>

                    <!-- Placeholder when nothing is selected -->
                    <Border Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisInv}}"
                            AllowDrop="True">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Margin="20">
                                <!-- dashed outline -->
                                <Rectangle Stroke="{StaticResource Border}"
                                    StrokeThickness="2"
                                    RadiusX="12"
                                    RadiusY="12"
                                    StrokeDashArray="4 4"
                                    Fill="Transparent"/>

                                <!-- content -->
                                <Border Padding="40,30" Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="&#xE896;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="48"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>

                                        <TextBlock Text="Select an item to preview"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>

                                        <TextBlock Text="or drag &amp; drop a JSON / XML file here"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- =========================================================
             ROW 2 — STATUS BAR
             ========================================================= -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto" MaxHeight="60">
                    <ItemsControl ItemsSource="{Binding StatusLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource LogItemStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="1" Content="Clear" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ClearLogCommand}"
                        Padding="10,4" FontSize="11" VerticalAlignment="Top"/>
            </Grid>
        </Border>
    </Grid>
</Window>
